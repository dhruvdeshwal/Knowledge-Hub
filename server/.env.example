# Minimal example environment variables used by the Knowledge-Hub server
# Copy this file to `.env` and fill in the values for your environment.

# Server
PORT=4000

# Database (MongoDB connection URI)
MONGODB_URL=

# Cloudinary (for media uploads)
CLOUD_NAME=
API_KEY=
API_SECRET=

# Razorpay (payment gateway)
RAZORPAY_KEY=
RAZORPAY_SECRET=

# JWT secret used for signing authentication tokens
JWT_SECRET=

# Mailer (SMTP) credentials used to send emails
MAIL_HOST=
MAIL_USER=
MAIL_PASS=

# Folder name used for uploaded media in Cloudinary
FOLDER_NAME=

# Client URL (used by CORS in production)
CLIENT_URL=
